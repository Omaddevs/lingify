# ═══════════════════════════════════════════════════════════
#  LINGIFY — Environment Variables
#  1. Copy this file: cp .env.example .env
#  2. Fill in your values from Supabase Dashboard
#  3. Restart dev server: npm run dev
# ═══════════════════════════════════════════════════════════

# ── Supabase (required for real auth + database) ─────────────────────────────
# Get from: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── App config ────────────────────────────────────────────────────────────────
VITE_APP_NAME=Lingify
VITE_APP_URL=https://lingify.uz

# ── Payment (optional — for production Payme/Click integration) ───────────────
VITE_PAYME_MERCHANT_ID=your-payme-merchant-id
VITE_CLICK_MERCHANT_ID=your-click-merchant-id

# ── Analytics (optional) ──────────────────────────────────────────────────────
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── AI (optional — for real Claude API speaking feedback) ────────────────────
# Set in Supabase → Edge Functions → Secrets (NOT in .env — security!)
# ANTHROPIC_API_KEY=sk-ant-...

# ── NOTE ──────────────────────────────────────────────────────────────────────
# Without VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY the app runs in
# DEMO MODE — all data is stored in localStorage only.
# To enable real backend: run supabase/schema.sql in your Supabase SQL Editor
